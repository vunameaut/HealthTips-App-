## This file must *NOT* be checked into Version Control Systems,
# as it contains information specific to your local configuration.
#
# Location of the SDK. This is only used by Gradle.
# For customization when using a Version Control System, please read the
# header note.

# Android SDK location
sdk.dir=YOUR_ANDROID_SDK_PATH

# OpenAI API Configuration (Backup - currently not in use)
openai.api.key=YOUR_OPENAI_API_KEY_HERE

# Google Gemini API Configuration (Currently Active)
# Get your API key from: https://makersuite.google.com/app/apikey
gemini.api.key=YOUR_GEMINI_API_KEY_HERE

# Cloudinary API Configuration (Optional)
cloudinary.api.key=YOUR_CLOUDINARY_API_KEY
cloudinary.api.secret=YOUR_CLOUDINARY_API_SECRET

# Firebase Auth Configuration (Optional)
firebase.auth.key=YOUR_FIREBASE_AUTH_KEY

